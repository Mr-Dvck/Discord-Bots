NEXT_PUBLIC_APP_NAME=Jamie Dashboard
DISCORD_BOT_TOKEN_JAMIE=your_discord_bot_token_here
OPENROUTER_API_KEY=your_openrouter_api_key_here
JAMIE_LLM_MODEL=qwen/qwen-2.5-72b-instruct
JAMIE_LLM_API_BASE=https://openrouter.ai/api/v1
# Path to the Jamie bot's SQLite database (required for welcome/starboard config)
# On Vercel, set this to the absolute path where the database is stored
JAMIE_DB_PATH=/path/to/jamie/db/data/jamie.db